{
    "name": "@mashroom/mashroom-storage-provider-mongodb",
    "description": "Mashroom storage provider backed by MongoDB",
    "homepage": "https://www.mashroom-server.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nonblocking/mashroom.git"
    },
    "license": "MIT",
    "version": "3.0.0-alpha.0",
    "files": [
        "dist/**",
        "mashroom.json"
    ],
    "dependencies": {
        "mongodb": "^7.5.0"
    },
    "devDependencies": {
        "@mashroom/mashroom": "3.0.0-alpha.0",
        "@mashroom/mashroom-monitoring-metrics-collector": "3.0.0-alpha.0",
        "@mashroom/mashroom-storage": "3.0.0-alpha.0",
        "@mashroom/mashroom-utils": "3.0.0-alpha.0",
        "@shelf/jest-mongodb": "^6.0.2"
    },
    "jest": {
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/test"
        ],
        "testRegex": "(\\.(test|spec))\\.ts",
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "preset": "@shelf/jest-mongodb",
        "reporters": [
            "default",
            "jest-junit"
        ]
    },
    "jest-junit": {
        "outputDirectory": "./test-reports"
    },
    "scripts": {
        "lint": "eslint --fix",
        "type-check": "tsc --noEmit",
        "test": "jest",
        "build": "babel src -d dist --extensions \".ts\""
    },
    "lavamoat": {
        "allowScripts": {
            "@shelf/jest-mongodb>mongodb-memory-server": false,
            "@shelf/jest-mongodb>@swc/jest>@swc/core": false
        }
    }
}
