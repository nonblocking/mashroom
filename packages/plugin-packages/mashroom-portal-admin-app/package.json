{
    "name": "@mashroom/mashroom-portal-admin-app",
    "description": "Mashroom Portal default Admin Toolbar",
    "homepage": "https://www.mashroom-server.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nonblocking/mashroom.git"
    },
    "license": "MIT",
    "version": "3.0.0-alpha.0",
    "files": [
        "dist/**",
        "mashroom.json"
    ],
    "devDependencies": {
        "@mashroom/mashroom": "3.0.0-alpha.0",
        "@mashroom/mashroom-portal": "3.0.0-alpha.0",
        "@mashroom/mashroom-portal-ui-commons": "3.0.0-alpha.0",
        "@types/latinize": "^0.2.18",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "formik": "^2.4.9",
        "latinize": "^2.0.0",
        "react": "^19.2.8",
        "react-dom": "^19.2.8",
        "react-i18next": "^17.0.10",
        "zustand": "^5.0.14"
    },
    "jest": {
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/test"
        ],
        "testRegex": "(\\.(test|spec))\\.ts",
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "reporters": [
            "default",
            "jest-junit"
        ]
    },
    "jest-junit": {
        "outputDirectory": "./test-reports"
    },
    "scripts": {
        "lint": "eslint --fix",
        "type-check": "tsc --noEmit",
        "test": "jest",
        "dev": "webpack serve --hot --mode development",
        "build": "webpack --mode production"
    }
}
