{
    "name": "@mashroom/parent",
    "private": true,
    "version": "",
    "engines": {
        "node": ">=20",
        "npm": ">=10"
    },
    "workspaces": [
        "packages/core/*",
        "packages/plugin-packages/*",
        "packages/plugin-packages-legacy/*",
        "packages/test/*"
    ],
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@lavamoat/allow-scripts": "^3.4.3",
        "@nrwl/nx-cloud": "^19.1.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.19.35",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "babel-loader": "^10.0.0",
        "cpy-cli": "^7.0.0",
        "del-cli": "^7.0.0",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "eslint": "^9.39.3",
        "@eslint/js": "^9.39.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^17.4.0",
        "jest": "^30.2.0",
        "jest-junit": "^16.0.0",
        "ts-jest": "^29.4.6",
        "lerna": "^9.0.5",
        "mini-css-extract-plugin": "^2.10.0",
        "nock": "^14.0.11",
        "nodemon": "^3.1.14",
        "http-server": "^14.1.1",
        "null-loader": "^4.0.1",
        "rimraf": "^6.1.3",
        "sass": "^1.97.3",
        "sass-loader": "^16.0.7",
        "style-loader": "^4.0.0",
        "postcss": "^8.5.6",
        "cssnano": "^7.1.2",
        "postcss-loader": "^8.2.1",
        "svg-inline-loader": "^0.8.2",
        "terser-webpack-plugin": "^5.3.16",
        "typescript": "^5.9.3",
        "webpack": "^5.105.3",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.3",
        "webpack-merge": "^6.0.1",
        "webpack-node-externals": "3.0.0"
    },
    "overrides": {
        "@types/readable-stream": "4.0.10"
    },
    "scripts": {
        "setup": "npm install && allow-scripts && lerna exec -- allow-scripts && npm run build:core",
        "type-check": "lerna run type-check",
        "lint": "lerna run lint",
        "test": "lerna run test",
        "build:core": "nx build @mashroom/mashroom-utils && nx build @mashroom/mashroom && nx build @mashroom/mashroom-json-schemas && nx build @mashroom/mashroom-portal-ui-commons",
        "build:plugins": "lerna run build",
        "build": "npm run build:core && npm run type-check && npm run lint && npm run test && npm run build:plugins",
        "clean": "rimraf node_modules/ packages/core/*/dist/ packages/core/*/lib/ packages/core/*/test-reports/ packages/core/*/test-data/ packages/core/*/node_modules/ packages/plugin-packages/*/dist/ packages/plugin-packages/*/node_modules/ packages/plugin-packages/*/test-reports/ packages/plugin-packages/*/node_modules/ packages/plugin-packages/*/test-data/ packages/plugin-packages-legacy/*/dist/ packages/plugin-packages-legacy/*/node_modules/ packages/plugin-packages-legacy/*/test-reports/ packages/plugin-packages-legacy/*/node_modules/ packages/plugin-packages-legacy/*/test-data/ packages/test/*/node_modules/ packages/test/*/data/ packages/test/*/log/ .nx/ lerna-debug.log"
    },
    "lavamoat": {
        "allowScripts": {
            "lerna>nx": true,
            "@lavamoat/allow-scripts>@lavamoat/preinstall-always-fail": false,
            "sass>@parcel/watcher": false,
            "jest>@jest/core>jest-resolve>unrs-resolver": false,
            "lerna>nx>@swc/core": false
        }
    }
}
